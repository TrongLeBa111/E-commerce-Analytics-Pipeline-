import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import seaborn as sns
import plotly.express as px
from sqlalchemy import create_engine
from dotenv import load_dotenv
from pathlib import Path
import os
import warnings
warnings.filterwarnings('ignore')

# Setup style
plt.rcParams['figure.figsize'] = (12, 6)
plt.rcParams['font.size'] = 12
sns.set_palette("husl")

# Kết nối database
load_dotenv(Path("../.env"))
engine = create_engine(
    f"postgresql://{os.getenv('POSTGRES_USER')}:"
    f"{os.getenv('POSTGRES_PASSWORD')}@localhost:5432/"
    f"{os.getenv('POSTGRES_DB')}"
)

# Load từ marts layer
df_orders = pd.read_sql("""
    SELECT
        f.*,
        c.state,
        c.city
    FROM marts.fct_orders f
    JOIN marts.dim_customers c ON f.customer_id = c.customer_id
""", engine, parse_dates=['purchased_at', 'delivered_to_customer_at', 'estimated_delivery_at'])

print(f"Loaded {len(df_orders):,} orders")
df_orders.head()